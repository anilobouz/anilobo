import os
import telebot
from flask import Flask, request

# Bot tokiningizni bu yerga qo'ying
BOT_TOKEN = "BOT_TOKENINGIZNI_SHU_YERGA_YOZING"
bot = telebot.TeleBot(BOT_TOKEN)

# Vercel talab qilayotgan 'app' obyektini yaratamiz
app = Flask(__name__)

# Foydalanuvchi start bossa javob beradi
@bot.message_handler(commands=['start'])
def send_welcome(message):
    bot.reply_to(message, "Salom! Bu Vercel-da 24/7 ishlaydigan anime bot!")

# Kodlar bo'limi: Agar foydalanuvchi raqam (kod) yozsa:
@bot.message_handler(func=lambda message: message.text.isdigit())
def send_anime(message):
    anime_code = message.text
    # Bu yerda kelajakda kod yozganda anime jo'natadigan qism bo'ladi
    bot.send_message(message.chat.id, f"Siz {anime_code} kodini yubordingiz. Tez orada anime yuklanadi!")

# Vercel so'rovlarini qabul qilish uchun yo'lak (Webhook)
@app.route('/' + BOT_TOKEN, methods=['POST'])
def getMessage():
    json_string = request.get_data().decode('utf-8')
    update = telebot.types.Update.de_json(json_string)
    bot.process_new_updates([update])
    return "!", 200

@app.route("/")
def webhook():
    bot.remove_webhook()
    # Bu yerga Vercel sizga beradigan yakuniy sayt manzili qo'yiladi
    # Hozircha bo'sh tursin, deploy bo'gandan keyin ulaymiz
    return "Bot ishlamoqda!", 200
    
